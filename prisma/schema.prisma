generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// The cached snapshot of a tenant's profile, pushed by main backend
// via PUT /ai/v1/businesses/{id}. Main backend is the source of truth;
// this is a synced replica that exists only to feed the prompt compiler.
model BusinessProfile {
  id                    String   @id
  name                  String
  description           String
  language              String   @default("en")
  tone                  Json
  hours                 Json
  faqs                  Json
  policies              Json
  escalation            Json
  // Optional commercial surface. Prices/thresholds are NPR by convention for
  // the Nepal/Kathmandu target market.
  product_catalog       Json?
  locations             Json?
  current_offers        Json?
  high_value_threshold  Int?
  version               Int      @default(1)
  active                Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
}

// One row per pipeline run. AI-team observability only — not surfaced
// to tenants.
model TurnLog {
  id                       String   @id @default(uuid())
  business_id              String
  conversation_id          String
  contact_id               String
  channel                  String
  ts                       DateTime @default(now())
  status                   String
  triage                   Json
  attempts                 Json
  validator_pass           Boolean  @default(false)
  retry_count              Int      @default(0)
  high_severity_violations Int      @default(0)
  intent_path              String?
  language                 String?
  shipped                  String
  tokens_in                Int?
  tokens_out               Int?
  duration_ms              Int
  trace_id                 String?
  model_triage             String?
  model_generator          String?
  model_validator          String?

  @@index([business_id, ts])
  @@index([trace_id])
  @@index([business_id, conversation_id, ts])
}
