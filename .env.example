PORT=8000

# ai-backend's own Redis — prompt cache, profile cache, request dedupe
REDIS_URL=redis://localhost:6379

# Shared Redis with main-backend — BullMQ job queue only
BULLMQ_REDIS_URL=redis://localhost:6379

# main-backend internal API — cold cache profile fetch on Redis miss
MAIN_BACKEND_INTERNAL_URL=http://localhost:3000

# Single shared secret — same value as AI_INTERNAL_API_TOKEN in main-backend .env
# Covers both directions: sent to main-backend (cold cache) and checked by InternalTokenGuard
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MAIN_BACKEND_INTERNAL_TOKEN=

OPENROUTER_API_KEY=

OPENROUTER_MODEL=anthropic/claude-haiku-4.5

USE_MULTI_MODEL_PIPELINE=true

PIPELINE_TRIAGE_MODEL=anthropic/claude-haiku-4.5
PIPELINE_GENERATOR_MODEL=anthropic/claude-sonnet-4-6
PIPELINE_GENERATOR_MODEL_HIGH_VALUE=anthropic/claude-opus-4-7
PIPELINE_VALIDATOR_MODEL=anthropic/claude-haiku-4.5

PIPELINE_TRIAGE_TIMEOUT_MS=4500
PIPELINE_GENERATOR_TIMEOUT_MS=10000
PIPELINE_VALIDATOR_TIMEOUT_MS=4500

PIPELINE_MAX_RETRIES=1
